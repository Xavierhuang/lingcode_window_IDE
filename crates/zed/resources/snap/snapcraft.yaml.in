name: lingcode
title: LingCode
base: core24
version: "$RELEASE_VERSION"
summary: The editor for what's next
description: |
  LingCode is a modern code editor, built from the ground up in Rust with
  a GPU-accelerated renderer. We help you build software faster than ever before.
grade: stable
confinement: classic
compression: lzo
website: https://lingcode.dev/
source-code: https://lingcode.dev
issues: https://lingcode.dev
contact: https://lingcode.dev

parts:
  lingcode:
    plugin: dump
    # PLACEHOLDER: needs a real LingCode Linux release artifact before a snap build will work.
    source: "https://lingcode.dev/releases/download/v$RELEASE_VERSION/lingcode-linux-x86_64.tar.gz"

    organize:
      # These renames seem to not be necessary, but it's tidier.
      bin: usr/bin
      libexec: usr/libexec

    stage-packages:
      - libasound2t64
      # snapcraft has a lint that this is unused, but without it LingCode exits with
      # "Missing Vulkan entry points: LibraryLoadFailure" in wgpu.
      - libvulkan1
      # snapcraft has a lint that this is unused, but without it LingCode exits with
      # "NoWaylandLib" when run with Wayland.
      - libwayland-client0
      - libxcb1
      - libxkbcommon-x11-0
      - libxkbcommon0

    build-attributes:
      - enable-patchelf

    prime:
      # Omit unneeded files from the tarball
      - -lib
      - -licenses.md
      - -share

      # Omit unneeded files from stage-packages
      - -etc
      - -usr/share/doc
      - -usr/share/lintian
      - -usr/share/man

apps:
  lingcode:
    command: usr/bin/lingcode
    common-id: dev.lingcode.LingCode
    environment:
      ZED_BUNDLE_TYPE: snap
